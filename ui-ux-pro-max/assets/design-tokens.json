{
  "primitive": {
    "color": {
      "blue": {
        "50": "#EFF6FF",
        "100": "#DBEAFE",
        "500": "#3B82F6",
        "600": "#2563EB",
        "900": "#1E3A8A"
      },
      "gray": {
        "50": "#F9FAFB",
        "100": "#F3F4F6",
        "200": "#E5E7EB",
        "300": "#D1D5DB",
        "400": "#9CA3AF",
        "500": "#6B7280",
        "600": "#4B5563",
        "700": "#374151",
        "800": "#1F2937",
        "900": "#111827"
      }
    },
    "spacing": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px"
    }
  },
  "semantic": {
    "color": {
      "primary": "{color.blue.600}",
      "text-primary": "{color.gray.900}",
      "text-secondary": "{color.gray.600}",
      "bg-primary": "#FFFFFF",
      "bg-secondary": "{color.gray.50}"
    }
  },
  "component": {
    "button": {
      "bg": "{color.primary}",
      "bg-hover": "{color.blue.700}",
      "text": "#FFFFFF",
      "padding": "{spacing.2} {spacing.4}",
      "radius": "{radius.md}"
    }
  }
}
